<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ethioride.admin.controller.DashboardController"
            stylesheets="@../styles/dark-theme.css"
            style="-fx-background-color:#0a0e1a;"
            prefWidth="1100" prefHeight="720">

    <!-- Top bar -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
            <Label text="EthioRide Dashboard"
                   style="-fx-text-fill:#f1f5f9; -fx-font-size:15px; -fx-font-weight:bold;"/>
            <!-- Tab nav -->
            <Button text="Fleet"    styleClass="nav-item" style="-fx-padding:8 12; -fx-cursor:hand;" onAction="#onTabFleet"/>
            <Button text="Drivers"  styleClass="nav-item" style="-fx-padding:8 12; -fx-cursor:hand;" onAction="#onTabDrivers"/>
            <Button text="Earnings" styleClass="nav-item" style="-fx-padding:8 12; -fx-cursor:hand;" onAction="#onTabEarnings"/>
            <Button text="Live Map" styleClass="nav-item"
                    style="-fx-padding:8 12; -fx-cursor:hand; -fx-text-fill:#3b82f6; -fx-border-color:transparent transparent #3b82f6 transparent; -fx-border-width:0 0 2 0;"
                    onAction="#onTabLiveMap"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="● Emergency Alert" styleClass="btn-danger" onAction="#onEmergencyAlert"/>
            <Button text="🔔" style="-fx-background-color:transparent; -fx-text-fill:#94a3b8; -fx-cursor:hand; -fx-font-size:16px;"/>
            <Button text="🌙" style="-fx-background-color:transparent; -fx-text-fill:#94a3b8; -fx-cursor:hand; -fx-font-size:16px;"/>
            <Button text="👤" style="-fx-background-color:transparent; -fx-text-fill:#94a3b8; -fx-cursor:hand; -fx-font-size:16px;"/>
        </HBox>
    </top>

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar" spacing="0" prefWidth="220">
            <VBox spacing="2" style="-fx-padding:24 20 20 20;">
                <Label text="EthioRide" styleClass="sidebar-logo"/>
                <Label text="PASSENGER SUITE" styleClass="sidebar-subtitle"/>
            </VBox>
            <VBox spacing="4" style="-fx-padding:0 12 0 12;" VBox.vgrow="ALWAYS">
                <Button text="🗺  Map View"    styleClass="nav-item" maxWidth="Infinity" onAction="#onNavDashboard"/>
                <Button text="🕐  Ride History" styleClass="nav-item" maxWidth="Infinity" onAction="#onNavTrips"/>
                <Button text="💳  Payments"    styleClass="nav-item" maxWidth="Infinity" onAction="#onNavPayments"/>
                <Button text="🏷  Promotions"  styleClass="nav-item" maxWidth="Infinity" onAction="#onNavPromotions"/>
                <Button text="⚙  Settings"    styleClass="nav-item,nav-item-active" maxWidth="Infinity" onAction="#onNavSystem"/>
            </VBox>
            <VBox spacing="0" style="-fx-padding:12 20 8 20; -fx-border-color:#1e3a5f; -fx-border-width:1 0 0 0;">
                <Button text="📍  Support"  styleClass="nav-item" maxWidth="Infinity" onAction="#onSupport"/>
                <Button text="↩  Sign Out" styleClass="nav-item" maxWidth="Infinity" onAction="#onSignOut"/>
            </VBox>
        </VBox>
    </left>

    <!-- Main content -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color:transparent; -fx-background:transparent;">
            <VBox spacing="20" style="-fx-padding:24;">

                <!-- System Health header -->
                <HBox alignment="CENTER_LEFT" spacing="24">
                    <VBox spacing="4">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="System Health: "
                                   style="-fx-text-fill:#f1f5f9; -fx-font-size:24px; -fx-font-weight:bold;"/>
                            <Label fx:id="lblHealthStatus"
                                   style="-fx-text-fill:#22c55e; -fx-font-size:24px; -fx-font-style:italic; -fx-font-weight:bold;"/>
                        </HBox>
                        <Label fx:id="lblHealthSubtitle" styleClass="label-subtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <VBox alignment="CENTER_RIGHT" spacing="2">
                        <Label text="LATENCY" styleClass="stat-label"/>
                        <Label fx:id="lblLatency"
                               style="-fx-text-fill:#f1f5f9; -fx-font-size:18px; -fx-font-weight:bold;"/>
                    </VBox>
                    <VBox alignment="CENTER_RIGHT" spacing="2">
                        <Label text="UPTIME" styleClass="stat-label"/>
                        <Label fx:id="lblUptime"
                               style="-fx-text-fill:#f1f5f9; -fx-font-size:18px; -fx-font-weight:bold;"/>
                    </VBox>
                </HBox>

                <!-- Stat cards -->
                <HBox spacing="16">
                    <!-- Active Drivers -->
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="🚗" style="-fx-font-size:16px;"/>
                            <Label text="LIVE METRIC" styleClass="stat-label"/>
                        </HBox>
                        <Label text="ACTIVE DRIVERS" styleClass="stat-label"/>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label fx:id="lblActiveDrivers" styleClass="stat-value"/>
                            <Label fx:id="lblDriversDelta"
                                   style="-fx-text-fill:#22c55e; -fx-font-size:12px;"/>
                        </HBox>
                        <Label text="Utilization" styleClass="label-subtitle"/>
                        <ProgressBar fx:id="driversUtilization" prefWidth="Infinity" prefHeight="6"/>
                    </VBox>

                    <!-- Ongoing Trips -->
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="🔄" style="-fx-font-size:16px;"/>
                            <Label text="HIGH DEMAND" style="-fx-text-fill:#f59e0b; -fx-font-size:9px;"/>
                        </HBox>
                        <Label text="ONGOING TRIPS" styleClass="stat-label"/>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label fx:id="lblOngoingTrips" styleClass="stat-value"/>
                            <Label fx:id="lblPeakHour"
                                   style="-fx-text-fill:#f59e0b; -fx-font-size:11px;"/>
                        </HBox>
                        <Label text="Target Goal" styleClass="label-subtitle"/>
                        <ProgressBar fx:id="tripsProgress" prefWidth="Infinity" prefHeight="6"/>
                    </VBox>

                    <!-- Server Heartbeat -->
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="💓" style="-fx-font-size:16px;"/>
                            <Label text="SERVER HEARTBEAT" styleClass="stat-label"/>
                        </HBox>
                        <Label fx:id="lblHeartbeat"
                               style="-fx-text-fill:#22c55e; -fx-font-size:22px; -fx-font-weight:bold;"/>
                        <Label text="LOAD" styleClass="stat-label"/>
                        <ProgressBar fx:id="serverLoad" prefWidth="Infinity" prefHeight="6"/>
                    </VBox>
                </HBox>

                <!-- Bottom row: logs + localization + fleet -->
                <HBox spacing="16">

                    <!-- Live Socket Logs -->
                    <VBox styleClass="card" spacing="12" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="⚡ LIVE SOCKET CONNECTION LOGS"
                                   style="-fx-text-fill:#475569; -fx-font-size:10px; -fx-font-weight:bold;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="PAUSE STREAM" styleClass="btn-secondary" onAction="#onPauseStream"/>
                            <Button text="CLEAR"        styleClass="btn-secondary" onAction="#onClearLogs"/>
                        </HBox>
                        <ScrollPane fx:id="logScrollPane" prefHeight="220" fitToWidth="true"
                                    style="-fx-background-color:#080d18; -fx-background:#080d18; -fx-background-radius:8px;">
                            <VBox fx:id="logContainer" spacing="2"
                                  style="-fx-padding:8; -fx-background-color:#080d18;"/>
                        </ScrollPane>
                        <HBox spacing="20">
                            <Label fx:id="lblTcpReqs"      styleClass="label-subtitle"/>
                            <Label fx:id="lblWsConnections" styleClass="label-subtitle"/>
                            <Label fx:id="lblMemUsage"      styleClass="label-subtitle"/>
                        </HBox>
                    </VBox>

                    <!-- Right column -->
                    <VBox spacing="16" prefWidth="280">

                        <!-- System Localization -->
                        <VBox styleClass="card" spacing="12">
                            <Label text="SYSTEM LOCALIZATION"
                                   style="-fx-text-fill:#475569; -fx-font-size:10px; -fx-font-weight:bold;"/>
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <ComboBox fx:id="cbLanguage" prefWidth="160" onAction="#onLanguageChange"/>
                                <Label text="Default"
                                       style="-fx-background-color:#1e3a5f; -fx-text-fill:#94a3b8; -fx-padding:4 8; -fx-background-radius:4px; -fx-font-size:10px;"/>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <ComboBox fx:id="cbScript" prefWidth="160" onAction="#onScriptChange"/>
                                <Button text="✕" style="-fx-background-color:transparent; -fx-text-fill:#475569; -fx-cursor:hand;" onAction="#onRemoveScript"/>
                            </HBox>
                            <Label fx:id="lblLocalizationNote" styleClass="label-subtitle" wrapText="true"/>
                        </VBox>

                        <!-- Fleet Analytics -->
                        <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">
                            <Label text="FLEET ANALYTICS"
                                   style="-fx-text-fill:#475569; -fx-font-size:10px; -fx-font-weight:bold;"/>
                            <HBox alignment="CENTER_LEFT" spacing="4">
                                <Label text="Projected Demand: "
                                       style="-fx-text-fill:#f1f5f9; -fx-font-size:14px; -fx-font-weight:bold;"/>
                                <Label fx:id="lblProjectedDemand"
                                       style="-fx-text-fill:#22c55e; -fx-font-size:14px; -fx-font-weight:bold;"/>
                            </HBox>
                            <StackPane style="-fx-background-color:#0d1526; -fx-background-radius:8px; -fx-min-height:120px;"
                                       alignment="CENTER">
                                <Label text="LIVE DEPLOYMENT"
                                       style="-fx-text-fill:#475569; -fx-font-size:11px; -fx-font-weight:bold;"/>
                            </StackPane>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
