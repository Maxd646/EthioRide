<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ethioride.admin.controller.SystemController"
            stylesheets="@../styles/dark-theme.css"
            style="-fx-background-color:#0a0e1a;"
            prefWidth="1100" prefHeight="720">

    <left>
        <VBox styleClass="sidebar" spacing="0" prefWidth="220">
            <VBox spacing="2" style="-fx-padding:24 20 20 20;">
                <Label text="EthioRide" styleClass="sidebar-logo"/>
                <Label text="SYSTEM MONITOR" styleClass="sidebar-subtitle"/>
            </VBox>
            <VBox spacing="4" style="-fx-padding:0 12 0 12;" VBox.vgrow="ALWAYS">
                <Button text="📊  Dashboard" styleClass="nav-item" maxWidth="Infinity" onAction="#onNavDashboard"/>
                <Button text="🚗  Drivers"   styleClass="nav-item" maxWidth="Infinity" onAction="#onNavDrivers"/>
                <Button text="🗺  Trips"     styleClass="nav-item" maxWidth="Infinity" onAction="#onNavTrips"/>
                <Button text="🖥  System"    styleClass="nav-item,nav-item-active" maxWidth="Infinity" onAction="#onNavSystem"/>
            </VBox>
            <VBox spacing="0" style="-fx-padding:12 20 8 20; -fx-border-color:#1e3a5f; -fx-border-width:1 0 0 0;">
                <Button text="📍  Support"  styleClass="nav-item" maxWidth="Infinity" onAction="#onSupport"/>
                <Button text="↩  Sign Out" styleClass="nav-item" maxWidth="Infinity" onAction="#onSignOut"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color:transparent; -fx-background:transparent;">
            <VBox spacing="20" style="-fx-padding:24;">

                <Label text="System Health" styleClass="label-title"/>

                <!-- Metrics row -->
                <HBox spacing="16">
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="TCP REQUESTS" styleClass="stat-label"/>
                        <Label fx:id="lblTcpReqs" styleClass="stat-value"/>
                        <ProgressBar fx:id="tcpProgress" prefWidth="Infinity" prefHeight="6"/>
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="WS CONNECTIONS" styleClass="stat-label"/>
                        <Label fx:id="lblWsConns" styleClass="stat-value"/>
                        <ProgressBar fx:id="wsProgress" prefWidth="Infinity" prefHeight="6"/>
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="MEMORY USAGE" styleClass="stat-label"/>
                        <Label fx:id="lblMemUsage" styleClass="stat-value"/>
                        <ProgressBar fx:id="memProgress" prefWidth="Infinity" prefHeight="6"/>
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="SERVER LOAD" styleClass="stat-label"/>
                        <Label fx:id="lblServerLoad" styleClass="stat-value"/>
                        <ProgressBar fx:id="loadProgress" prefWidth="Infinity" prefHeight="6"/>
                    </VBox>
                </HBox>

                <!-- Full log console -->
                <VBox styleClass="card" spacing="12">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="⚡ FULL SYSTEM LOG"
                               style="-fx-text-fill:#475569; -fx-font-size:10px; -fx-font-weight:bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="PAUSE" styleClass="btn-secondary" onAction="#onPause"/>
                        <Button text="CLEAR" styleClass="btn-secondary" onAction="#onClear"/>
                        <Button text="EXPORT" styleClass="btn-secondary" onAction="#onExport"/>
                    </HBox>
                    <ScrollPane fx:id="logScrollPane" prefHeight="340" fitToWidth="true"
                                style="-fx-background-color:#080d18; -fx-background:#080d18; -fx-background-radius:8px;">
                        <VBox fx:id="logContainer" spacing="2"
                              style="-fx-padding:8; -fx-background-color:#080d18;"/>
                    </ScrollPane>
                </VBox>

                <!-- Server controls -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Server Controls:" style="-fx-text-fill:#94a3b8; -fx-font-size:13px;"/>
                    <Button text="Send Heartbeat" styleClass="btn-secondary" onAction="#onSendHeartbeat"/>
                    <Button text="Restart Server" styleClass="btn-danger"    onAction="#onRestartServer"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
