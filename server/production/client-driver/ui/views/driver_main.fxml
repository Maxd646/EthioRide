<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ethioride.driver.ui.controllers.DriverMainController"
            stylesheets="@../styles/dark-theme.css"
            style="-fx-background-color:#0a0e1a;"
            prefWidth="1100" prefHeight="720">

    <!-- Top Bar -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
            <Label text="EthioRide Dashboard" style="-fx-text-fill:#f1f5f9; -fx-font-size:15px; -fx-font-weight:bold;"/>
            <!-- Online toggle -->
            <ToggleButton fx:id="toggleOnline" styleClass="toggle-button" onAction="#onToggleOnline"/>
            <Region HBox.hgrow="ALWAYS"/>
            <!-- Nav tabs -->
            <Button fx:id="btnTabLiveMap" text="Live Map" styleClass="nav-item-active"
                    style="-fx-background-color:transparent; -fx-text-fill:#3b82f6; -fx-border-color:transparent transparent #3b82f6 transparent; -fx-border-width:0 0 2 0; -fx-cursor:hand; -fx-padding:8 12;"
                    onAction="#onTabLiveMap"/>
            <Button fx:id="btnTabFleet" text="Fleet" styleClass="nav-item"
                    style="-fx-background-color:transparent; -fx-text-fill:#94a3b8; -fx-cursor:hand; -fx-padding:8 12;"
                    onAction="#onTabFleet"/>
            <Button fx:id="btnTabEarnings" text="Earnings" styleClass="nav-item"
                    style="-fx-background-color:transparent; -fx-text-fill:#94a3b8; -fx-cursor:hand; -fx-padding:8 12;"
                    onAction="#onTabEarnings"/>
            <Button fx:id="btnTabDrivers" text="Drivers" styleClass="nav-item"
                    style="-fx-background-color:transparent; -fx-text-fill:#94a3b8; -fx-cursor:hand; -fx-padding:8 12;"
                    onAction="#onTabDrivers"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnEmergency" text="● Emergency Alert"
                    style="-fx-background-color:#ef4444; -fx-text-fill:white; -fx-font-size:12px; -fx-font-weight:bold; -fx-padding:8 16; -fx-background-radius:6px; -fx-cursor:hand;"
                    onAction="#onEmergencyAlert"/>
            <Button text="🔔" style="-fx-background-color:transparent; -fx-text-fill:#94a3b8; -fx-cursor:hand; -fx-font-size:16px;"/>
            <Button text="🌙" style="-fx-background-color:transparent; -fx-text-fill:#94a3b8; -fx-cursor:hand; -fx-font-size:16px;"/>
            <Button text="👤" style="-fx-background-color:transparent; -fx-text-fill:#94a3b8; -fx-cursor:hand; -fx-font-size:16px;"/>
        </HBox>
    </top>

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar" spacing="0" prefWidth="220">
            <VBox spacing="2" style="-fx-padding:24 20 20 20;">
                <Label text="EthioRide" styleClass="sidebar-logo"/>
                <Label text="PASSENGER SUITE" styleClass="sidebar-subtitle"/>
            </VBox>
            <VBox spacing="4" style="-fx-padding:0 12 0 12;" VBox.vgrow="ALWAYS">
                <Button fx:id="btnNavMap" text="🗺  Map View" styleClass="nav-item,nav-item-active" maxWidth="Infinity" onAction="#onNavMap"/>
                <Button fx:id="btnNavHistory" text="🕐  Ride History" styleClass="nav-item" maxWidth="Infinity" onAction="#onNavHistory"/>
                <Button fx:id="btnNavPayments" text="💳  Payments" styleClass="nav-item" maxWidth="Infinity" onAction="#onNavPayments"/>
                <Button fx:id="btnNavPromotions" text="🏷  Promotions" styleClass="nav-item" maxWidth="Infinity" onAction="#onNavPromotions"/>
                <Button fx:id="btnNavSettings" text="⚙  Settings" styleClass="nav-item" maxWidth="Infinity" onAction="#onNavSettings"/>
            </VBox>
            <VBox spacing="0" style="-fx-padding:12 20 8 20; -fx-border-color:#1e3a5f; -fx-border-width:1 0 0 0;">
                <Button text="📍  Support" styleClass="nav-item" maxWidth="Infinity" onAction="#onSupport"/>
                <Button text="↩  Sign Out" styleClass="nav-item" maxWidth="Infinity" onAction="#onSignOut"/>
            </VBox>
        </VBox>
    </left>

    <!-- Main content -->
    <center>
        <StackPane fx:id="contentArea">
            <!-- Map background -->
            <Pane fx:id="mapPane" styleClass="map-placeholder"/>

            <!-- Ride request popup (shown when new request arrives) -->
            <StackPane fx:id="requestOverlay" visible="false" managed="false"
                       style="-fx-background-color:rgba(0,0,0,0.5);">
                <VBox styleClass="request-card" alignment="TOP_LEFT" spacing="12" StackPane.alignment="CENTER">

                    <!-- Header row -->
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="NEW REQUEST" styleClass="new-request-badge"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <VBox alignment="CENTER">
                            <Label fx:id="lblCountdown" styleClass="countdown-label"/>
                            <Label text="EXPIRES" style="-fx-text-fill:#475569; -fx-font-size:9px;"/>
                        </VBox>
                    </HBox>

                    <!-- Fare -->
                    <Label fx:id="lblRequestFare" styleClass="label-price"/>

                    <!-- Pickup -->
                    <VBox spacing="4">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="⊙" style="-fx-text-fill:#3b82f6; -fx-font-size:12px;"/>
                            <VBox spacing="2">
                                <Label fx:id="lblPickupTag" styleClass="label-section"/>
                                <Label fx:id="lblPickupLocation" style="-fx-text-fill:#f1f5f9; -fx-font-size:13px;"/>
                            </VBox>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="▪" style="-fx-text-fill:#f59e0b; -fx-font-size:12px;"/>
                            <VBox spacing="2">
                                <Label fx:id="lblDropoffTag" styleClass="label-section"/>
                                <Label fx:id="lblDropoffLocation" style="-fx-text-fill:#f1f5f9; -fx-font-size:13px;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Passenger info -->
                    <HBox spacing="12" alignment="CENTER_LEFT"
                          style="-fx-background-color:#111827; -fx-background-radius:10px; -fx-padding:10;">
                        <StackPane style="-fx-background-color:#1e3a5f; -fx-background-radius:50%; -fx-min-width:40px; -fx-min-height:40px;" alignment="CENTER">
                            <Label text="👤" style="-fx-font-size:18px;"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label fx:id="lblPassengerName" style="-fx-text-fill:#f1f5f9; -fx-font-size:13px; -fx-font-weight:bold;"/>
                            <Label fx:id="lblPassengerRating" style="-fx-text-fill:#f59e0b; -fx-font-size:11px;"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <VBox alignment="CENTER_RIGHT" spacing="2">
                            <Label text="DISTANCE" style="-fx-text-fill:#475569; -fx-font-size:9px;"/>
                            <Label fx:id="lblDistance" style="-fx-text-fill:#f1f5f9; -fx-font-size:14px; -fx-font-weight:bold;"/>
                        </VBox>
                    </HBox>

                    <!-- Action buttons -->
                    <HBox spacing="12">
                        <Button text="Decline" styleClass="btn-secondary" onAction="#onDeclineRequest" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button text="ACCEPT REQUEST" styleClass="btn-primary" onAction="#onAcceptRequest" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                </VBox>
            </StackPane>

            <!-- Shift earnings bar (bottom left) -->
            <HBox fx:id="earningsBar" styleClass="earnings-bar" alignment="CENTER_LEFT" spacing="12"
                  style="-fx-max-width:200px; -fx-padding:10 16;"
                  StackPane.alignment="BOTTOM_LEFT">
                <VBox spacing="4">
                    <Label text="SHIFT EARNINGS" style="-fx-text-fill:#475569; -fx-font-size:9px;"/>
                    <Label fx:id="lblShiftEarnings" style="-fx-text-fill:#3b82f6; -fx-font-size:13px; -fx-font-weight:bold;"/>
                    <ProgressBar fx:id="earningsProgress" prefWidth="160" prefHeight="4"/>
                </VBox>
            </HBox>
        </StackPane>
    </center>
</BorderPane>
