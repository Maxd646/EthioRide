<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ethioride.driver.ui.controllers.EarningsController"
            stylesheets="@../styles/dark-theme.css"
            style="-fx-background-color:#0a0e1a;"
            prefWidth="1100" prefHeight="720">

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
            <Label text="EthioRide Dashboard" style="-fx-text-fill:#f1f5f9; -fx-font-size:15px; -fx-font-weight:bold;"/>
            <Button text="Live Map" styleClass="nav-item" style="-fx-padding:8 12; -fx-cursor:hand;" onAction="#onTabLiveMap"/>
            <Button text="Fleet"    styleClass="nav-item" style="-fx-padding:8 12; -fx-cursor:hand;" onAction="#onTabFleet"/>
            <Button text="Earnings" styleClass="nav-item"
                    style="-fx-padding:8 12; -fx-cursor:hand; -fx-text-fill:#3b82f6; -fx-border-color:transparent transparent #3b82f6 transparent; -fx-border-width:0 0 2 0;"
                    onAction="#onTabEarnings"/>
            <Button text="Drivers"  styleClass="nav-item" style="-fx-padding:8 12; -fx-cursor:hand;" onAction="#onTabDrivers"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="● Emergency Alert" style="-fx-background-color:#ef4444; -fx-text-fill:white; -fx-font-size:12px; -fx-font-weight:bold; -fx-padding:8 16; -fx-background-radius:6px; -fx-cursor:hand;" onAction="#onEmergency"/>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sidebar" spacing="0" prefWidth="220">
            <VBox spacing="2" style="-fx-padding:24 20 20 20;">
                <Label text="EthioRide" styleClass="sidebar-logo"/>
                <Label text="DRIVER DASHBOARD" styleClass="sidebar-subtitle"/>
            </VBox>
            <VBox spacing="4" style="-fx-padding:0 12 0 12;" VBox.vgrow="ALWAYS">
                <Button text="🗺  Map View"    styleClass="nav-item" maxWidth="Infinity" onAction="#onNavMap"/>
                <Button text="🕐  Ride History" styleClass="nav-item" maxWidth="Infinity" onAction="#onNavHistory"/>
                <Button text="💳  Payments"    styleClass="nav-item" maxWidth="Infinity" onAction="#onNavPayments"/>
                <Button text="🏷  Promotions"  styleClass="nav-item" maxWidth="Infinity" onAction="#onNavPromotions"/>
                <Button text="⚙  Settings"    styleClass="nav-item" maxWidth="Infinity" onAction="#onNavSettings"/>
            </VBox>
            <VBox spacing="0" style="-fx-padding:12 20 8 20; -fx-border-color:#1e3a5f; -fx-border-width:1 0 0 0;">
                <Button text="📍  Support"  styleClass="nav-item" maxWidth="Infinity" onAction="#onSupport"/>
                <Button text="↩  Sign Out" styleClass="nav-item" maxWidth="Infinity" onAction="#onSignOut"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="20" style="-fx-padding:28;">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label text="Earnings" styleClass="label-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="cbPeriod" prefWidth="140"
                          style="-fx-background-color:#0d1526; -fx-border-color:#1e3a5f; -fx-border-radius:6px;"
                          onAction="#onPeriodChange"/>
            </HBox>

            <!-- Stat cards -->
            <HBox spacing="12">
                <VBox styleClass="card" spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="THIS WEEK (ETB)" style="-fx-text-fill:#475569; -fx-font-size:10px;"/>
                    <Label fx:id="lblWeekEarnings" style="-fx-text-fill:#22c55e; -fx-font-size:28px; -fx-font-weight:bold;"/>
                </VBox>
                <VBox styleClass="card" spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="THIS MONTH (ETB)" style="-fx-text-fill:#475569; -fx-font-size:10px;"/>
                    <Label fx:id="lblMonthEarnings" style="-fx-text-fill:#3b82f6; -fx-font-size:28px; -fx-font-weight:bold;"/>
                </VBox>
                <VBox styleClass="card" spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="TRIPS THIS WEEK" style="-fx-text-fill:#475569; -fx-font-size:10px;"/>
                    <Label fx:id="lblWeekTrips" style="-fx-text-fill:#f1f5f9; -fx-font-size:28px; -fx-font-weight:bold;"/>
                </VBox>
                <VBox styleClass="card" spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="ONLINE HOURS" style="-fx-text-fill:#475569; -fx-font-size:10px;"/>
                    <Label fx:id="lblOnlineHours" style="-fx-text-fill:#f59e0b; -fx-font-size:28px; -fx-font-weight:bold;"/>
                </VBox>
            </HBox>

            <!-- Daily breakdown -->
            <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">
                <Label text="DAILY BREAKDOWN" style="-fx-text-fill:#475569; -fx-font-size:10px; -fx-font-weight:bold;"/>
                <ScrollPane fitToWidth="true" prefHeight="300"
                            style="-fx-background-color:transparent; -fx-background:transparent;">
                    <VBox fx:id="dailyContainer" spacing="8"/>
                </ScrollPane>
            </VBox>
        </VBox>
    </center>
</BorderPane>
