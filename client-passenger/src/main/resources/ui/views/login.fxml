<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.ethioride.passenger.ui.controllers.LoginController"
           stylesheets="@../styles/dark-theme.css"
           style="-fx-background-color: #0a0e1a;"
           prefWidth="480" prefHeight="700">

    <VBox alignment="CENTER" spacing="0" maxWidth="360" StackPane.alignment="CENTER">

        <!-- Logo -->
        <VBox alignment="CENTER" spacing="6" VBox.vgrow="NEVER">
            <padding><Insets top="40" bottom="20"/></padding>
            <Label text="EthioRide" styleClass="sidebar-logo" style="-fx-font-size:24px;"/>
        </VBox>

        <!-- Icon -->
        <StackPane alignment="CENTER" style="-fx-background-color:#1a2235; -fx-background-radius:16px;"
                   prefWidth="64" prefHeight="64">
            <Label text="🚕" style="-fx-font-size:28px;"/>
        </StackPane>

        <VBox spacing="4" alignment="CENTER">
            <padding><Insets top="16" bottom="4"/></padding>
            <Label fx:id="lblLoginTitle" styleClass="label-title" style="-fx-font-size:20px;"/>
            <Label fx:id="lblLoginSubtitle" styleClass="label-subtitle"/>
        </VBox>

        <!-- Form -->
        <VBox spacing="14" maxWidth="340">
            <padding><Insets top="24" bottom="0"/></padding>

            <!-- Phone -->
            <VBox spacing="6">
                <Label fx:id="lblPhone" styleClass="label-section"/>
                <HBox spacing="0" style="-fx-background-color:#0d1526; -fx-border-color:#1e3a5f; -fx-border-radius:8px; -fx-background-radius:8px;">
                    <Label text="+251" style="-fx-text-fill:#94a3b8; -fx-padding:10 10 10 14; -fx-font-size:13px;"/>
                    <Separator orientation="VERTICAL" style="-fx-background-color:#1e3a5f;"/>
                    <TextField fx:id="tfPhone" promptText="911 234 567"
                               style="-fx-background-color:transparent; -fx-text-fill:#f1f5f9; -fx-prompt-text-fill:#475569; -fx-border-color:transparent; -fx-padding:10 14 10 10; -fx-font-size:13px;"
                               HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <!-- Password -->
            <VBox spacing="6">
                <Label fx:id="lblPassword" styleClass="label-section"/>
                <HBox spacing="0" style="-fx-background-color:#0d1526; -fx-border-color:#1e3a5f; -fx-border-radius:8px; -fx-background-radius:8px;">
                    <Label text="🔒" style="-fx-padding:10 8 10 14; -fx-font-size:13px;"/>
                    <PasswordField fx:id="pfPassword" promptText="••••••••"
                                   style="-fx-background-color:transparent; -fx-text-fill:#f1f5f9; -fx-prompt-text-fill:#475569; -fx-border-color:transparent; -fx-padding:10 14 10 4; -fx-font-size:13px;"
                                   HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnTogglePassword" text="👁" onAction="#onTogglePassword"
                            style="-fx-background-color:transparent; -fx-text-fill:#475569; -fx-cursor:hand; -fx-padding:10 14 10 4;"/>
                </HBox>
                <HBox alignment="CENTER_RIGHT">
                    <Label fx:id="lblForgot" styleClass="label-link" onMouseClicked="#onForgotPassword"/>
                </HBox>
            </VBox>

            <!-- Error label -->
            <Label fx:id="lblError" style="-fx-text-fill:#ef4444; -fx-font-size:12px;" visible="false" managed="false"/>

            <!-- Login button -->
            <Button fx:id="btnLogin" styleClass="btn-primary" onAction="#onLogin"
                    maxWidth="Infinity" style="-fx-background-color:#3b82f6; -fx-text-fill:white; -fx-font-size:14px; -fx-font-weight:bold; -fx-padding:12; -fx-background-radius:10px; -fx-cursor:hand;"/>

            <!-- Divider -->
            <HBox alignment="CENTER" spacing="10">
                <padding><Insets top="4" bottom="4"/></padding>
                <Separator HBox.hgrow="ALWAYS"/>
                <Label text="or" style="-fx-text-fill:#475569; -fx-font-size:12px;"/>
                <Separator HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Social icons placeholder -->
            <HBox alignment="CENTER" spacing="16">
                <Button text="🌐" style="-fx-background-color:#1a2235; -fx-text-fill:#f1f5f9; -fx-background-radius:50%; -fx-min-width:40px; -fx-min-height:40px; -fx-cursor:hand;"/>
                <Button text="✉" style="-fx-background-color:#1a2235; -fx-text-fill:#f1f5f9; -fx-background-radius:50%; -fx-min-width:40px; -fx-min-height:40px; -fx-cursor:hand;"/>
            </HBox>

            <!-- Register link -->
            <HBox alignment="CENTER" spacing="4">
                <padding><Insets top="8" bottom="40"/></padding>
                <Label fx:id="lblNoAccount" styleClass="label-subtitle"/>
                <Label fx:id="lblCreateAccount" styleClass="label-link" onMouseClicked="#onCreateAccount"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
