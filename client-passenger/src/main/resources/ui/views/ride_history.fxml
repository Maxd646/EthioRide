<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ethioride.passenger.ui.controllers.RideHistoryController"
            stylesheets="@../styles/dark-theme.css"
            style="-fx-background-color:#0a0e1a;"
            prefWidth="1100" prefHeight="720">

    <left>
        <VBox styleClass="sidebar" spacing="0" prefWidth="220">
            <VBox spacing="2" style="-fx-padding:24 20 20 20;">
                <Label text="EthioRide" styleClass="sidebar-logo"/>
                <Label text="PASSENGER SUITE" styleClass="sidebar-subtitle"/>
            </VBox>
            <VBox spacing="4" style="-fx-padding:0 12 0 12;" VBox.vgrow="ALWAYS">
                <Button text="🗺  Map View"    styleClass="nav-item" maxWidth="Infinity" onAction="#onNavMap"/>
                <Button text="🕐  Ride History" styleClass="nav-item,nav-item-active" maxWidth="Infinity" onAction="#onNavHistory"/>
                <Button text="💳  Payments"    styleClass="nav-item" maxWidth="Infinity" onAction="#onNavPayments"/>
                <Button text="🏷  Promotions"  styleClass="nav-item" maxWidth="Infinity" onAction="#onNavPromotions"/>
                <Button text="⚙  Settings"    styleClass="nav-item" maxWidth="Infinity" onAction="#onNavSettings"/>
            </VBox>
            <VBox spacing="0" style="-fx-padding:12 20 8 20; -fx-border-color:#1e3a5f; -fx-border-width:1 0 0 0;">
                <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding:8 0;">
                    <StackPane style="-fx-background-color:#1e3a5f; -fx-background-radius:50%; -fx-min-width:36px; -fx-min-height:36px;" alignment="CENTER">
                        <Label text="👤" style="-fx-font-size:16px;"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="lblUserName" style="-fx-text-fill:#f1f5f9; -fx-font-size:13px; -fx-font-weight:bold;"/>
                        <Label fx:id="lblUserPhone" style="-fx-text-fill:#475569; -fx-font-size:11px;"/>
                    </VBox>
                </HBox>
                <Button text="📍  Support"  styleClass="nav-item" maxWidth="Infinity" onAction="#onSupport"/>
                <Button text="↩  Sign Out" styleClass="nav-item" maxWidth="Infinity" onAction="#onSignOut"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="16" style="-fx-padding:28;">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4">
                    <Label text="Ride History" styleClass="label-title"/>
                    <Label text="የጉዞ ታሪክ" styleClass="label-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="tfSearch" promptText="Search trips..."
                           style="-fx-background-color:#0d1526; -fx-text-fill:#f1f5f9; -fx-prompt-text-fill:#475569; -fx-border-color:#1e3a5f; -fx-border-radius:8px; -fx-background-radius:8px; -fx-padding:8 14; -fx-font-size:13px; -fx-min-width:200px;"
                           onKeyReleased="#onSearch"/>
                <ComboBox fx:id="cbFilter" prefWidth="130"
                          style="-fx-background-color:#0d1526; -fx-border-color:#1e3a5f; -fx-border-radius:6px;"
                          onAction="#onFilter"/>
            </HBox>

            <!-- Summary cards -->
            <HBox spacing="12">
                <VBox styleClass="card" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                    <Label text="TOTAL TRIPS" style="-fx-text-fill:#475569; -fx-font-size:10px;"/>
                    <Label fx:id="lblTotalTrips" style="-fx-text-fill:#f1f5f9; -fx-font-size:28px; -fx-font-weight:bold;"/>
                </VBox>
                <VBox styleClass="card" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                    <Label text="TOTAL SPENT (ETB)" style="-fx-text-fill:#475569; -fx-font-size:10px;"/>
                    <Label fx:id="lblTotalSpent" style="-fx-text-fill:#3b82f6; -fx-font-size:28px; -fx-font-weight:bold;"/>
                </VBox>
                <VBox styleClass="card" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                    <Label text="AVG RATING GIVEN" style="-fx-text-fill:#475569; -fx-font-size:10px;"/>
                    <Label fx:id="lblAvgRating" style="-fx-text-fill:#f59e0b; -fx-font-size:28px; -fx-font-weight:bold;"/>
                </VBox>
            </HBox>

            <!-- Trip list -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color:transparent; -fx-background:transparent;">
                <VBox fx:id="tripListContainer" spacing="10" style="-fx-padding:0 0 20 0;"/>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
