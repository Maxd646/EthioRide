<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ethioride.passenger.ui.controllers.PromotionsController"
            stylesheets="@../styles/dark-theme.css"
            style="-fx-background-color:#0a0e1a;"
            prefWidth="1100" prefHeight="720">

    <left>
        <VBox styleClass="sidebar" spacing="0" prefWidth="220">
            <VBox spacing="2" style="-fx-padding:24 20 20 20;">
                <Label text="EthioRide" styleClass="sidebar-logo"/>
                <Label text="PASSENGER SUITE" styleClass="sidebar-subtitle"/>
            </VBox>
            <VBox spacing="4" style="-fx-padding:0 12 0 12;" VBox.vgrow="ALWAYS">
                <Button text="🗺  Map View"    styleClass="nav-item" maxWidth="Infinity" onAction="#onNavMap"/>
                <Button text="🕐  Ride History" styleClass="nav-item" maxWidth="Infinity" onAction="#onNavHistory"/>
                <Button text="💳  Payments"    styleClass="nav-item" maxWidth="Infinity" onAction="#onNavPayments"/>
                <Button text="🏷  Promotions"  styleClass="nav-item,nav-item-active" maxWidth="Infinity" onAction="#onNavPromotions"/>
                <Button text="⚙  Settings"    styleClass="nav-item" maxWidth="Infinity" onAction="#onNavSettings"/>
            </VBox>
            <VBox spacing="0" style="-fx-padding:12 20 8 20; -fx-border-color:#1e3a5f; -fx-border-width:1 0 0 0;">
                <Button text="📍  Support"  styleClass="nav-item" maxWidth="Infinity" onAction="#onSupport"/>
                <Button text="↩  Sign Out" styleClass="nav-item" maxWidth="Infinity" onAction="#onSignOut"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="20" style="-fx-padding:28;">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4">
                    <Label text="Promotions" styleClass="label-title"/>
                    <Label text="ቅናሾች" styleClass="label-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="0" style="-fx-background-color:#0d1526; -fx-border-color:#1e3a5f; -fx-border-radius:8px; -fx-background-radius:8px;">
                    <TextField fx:id="tfPromoCode" promptText="Enter promo code"
                               style="-fx-background-color:transparent; -fx-text-fill:#f1f5f9; -fx-prompt-text-fill:#475569; -fx-border-color:transparent; -fx-padding:10 14; -fx-font-size:13px; -fx-min-width:200px;"/>
                    <Button text="Apply" styleClass="btn-primary"
                            style="-fx-font-size:12px; -fx-padding:10 16; -fx-background-radius:0 8 8 0;"
                            onAction="#onApplyCode"/>
                </HBox>
            </HBox>

            <!-- Active promos -->
            <Label text="ACTIVE PROMOTIONS" style="-fx-text-fill:#475569; -fx-font-size:10px; -fx-font-weight:bold;"/>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color:transparent; -fx-background:transparent;">
                <VBox fx:id="promoContainer" spacing="12" style="-fx-padding:0 0 20 0;"/>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
