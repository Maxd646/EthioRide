<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ethioride.passenger.ui.controllers.PaymentsController"
            stylesheets="@../styles/dark-theme.css"
            style="-fx-background-color:#0a0e1a;"
            prefWidth="1100" prefHeight="720">

    <left>
        <VBox styleClass="sidebar" spacing="0" prefWidth="220">
            <VBox spacing="2" style="-fx-padding:24 20 20 20;">
                <Label text="EthioRide" styleClass="sidebar-logo"/>
                <Label text="PASSENGER SUITE" styleClass="sidebar-subtitle"/>
            </VBox>
            <VBox spacing="4" style="-fx-padding:0 12 0 12;" VBox.vgrow="ALWAYS">
                <Button text="🗺  Map View"    styleClass="nav-item" maxWidth="Infinity" onAction="#onNavMap"/>
                <Button text="🕐  Ride History" styleClass="nav-item" maxWidth="Infinity" onAction="#onNavHistory"/>
                <Button text="💳  Payments"    styleClass="nav-item,nav-item-active" maxWidth="Infinity" onAction="#onNavPayments"/>
                <Button text="🏷  Promotions"  styleClass="nav-item" maxWidth="Infinity" onAction="#onNavPromotions"/>
                <Button text="⚙  Settings"    styleClass="nav-item" maxWidth="Infinity" onAction="#onNavSettings"/>
            </VBox>
            <VBox spacing="0" style="-fx-padding:12 20 8 20; -fx-border-color:#1e3a5f; -fx-border-width:1 0 0 0;">
                <Button text="📍  Support"  styleClass="nav-item" maxWidth="Infinity" onAction="#onSupport"/>
                <Button text="↩  Sign Out" styleClass="nav-item" maxWidth="Infinity" onAction="#onSignOut"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="20" style="-fx-padding:28;">

            <Label text="Payments" styleClass="label-title"/>

            <HBox spacing="16">
                <!-- Wallet card -->
                <VBox styleClass="card" spacing="12" HBox.hgrow="ALWAYS">
                    <Label text="ETHIORIDE WALLET" style="-fx-text-fill:#475569; -fx-font-size:10px; -fx-font-weight:bold;"/>
                    <Label fx:id="lblWalletBalance"
                           style="-fx-text-fill:#3b82f6; -fx-font-size:36px; -fx-font-weight:bold;"/>
                    <Label text="ETB Available" styleClass="label-subtitle"/>
                    <HBox spacing="10">
                        <Button text="+ Top Up" styleClass="btn-primary"
                                style="-fx-font-size:12px; -fx-padding:8 16;" onAction="#onTopUp"/>
                        <Button text="Withdraw" styleClass="btn-secondary"
                                style="-fx-font-size:12px; -fx-padding:8 16;" onAction="#onWithdraw"/>
                    </HBox>
                </VBox>

                <!-- Payment methods -->
                <VBox styleClass="card" spacing="12" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="PAYMENT METHODS" style="-fx-text-fill:#475569; -fx-font-size:10px; -fx-font-weight:bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="+ Add" styleClass="btn-secondary"
                                style="-fx-font-size:11px; -fx-padding:4 10;" onAction="#onAddPaymentMethod"/>
                    </HBox>
                    <VBox fx:id="paymentMethodsContainer" spacing="8"/>
                </VBox>
            </HBox>

            <!-- Transaction history -->
            <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="TRANSACTION HISTORY" style="-fx-text-fill:#475569; -fx-font-size:10px; -fx-font-weight:bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="cbTxFilter" prefWidth="120"
                              style="-fx-background-color:#0d1526; -fx-border-color:#1e3a5f; -fx-border-radius:6px;"
                              onAction="#onTxFilter"/>
                </HBox>
                <ScrollPane fitToWidth="true" prefHeight="300"
                            style="-fx-background-color:transparent; -fx-background:transparent;">
                    <VBox fx:id="txContainer" spacing="8"/>
                </ScrollPane>
            </VBox>
        </VBox>
    </center>
</BorderPane>
