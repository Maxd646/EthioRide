<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ethioride.passenger.ui.controllers.MainController"
            stylesheets="@../styles/dark-theme.css"
            style="-fx-background-color:#0a0e1a;"
            prefWidth="1100" prefHeight="720">

    <!-- Top Bar -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
            <Label text="📍" style="-fx-text-fill:#3b82f6; -fx-font-size:14px;"/>
            <Label fx:id="lblCurrentLocation" style="-fx-text-fill:#f1f5f9; -fx-font-size:13px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnNotification" text="🔔" style="-fx-background-color:transparent; -fx-text-fill:#94a3b8; -fx-cursor:hand; -fx-font-size:16px;"/>
            <Button fx:id="btnBookNow" styleClass="btn-book-now" onAction="#onBookNow"/>
        </HBox>
    </top>

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar" spacing="0" prefWidth="220">
            <!-- Logo -->
            <VBox spacing="2" style="-fx-padding:24 20 20 20;">
                <Label text="EthioRide" styleClass="sidebar-logo"/>
                <Label fx:id="lblSuiteTitle" styleClass="sidebar-subtitle"/>
            </VBox>

            <!-- Nav items -->
            <VBox spacing="4" style="-fx-padding:0 12 0 12;" VBox.vgrow="ALWAYS">
                <Button fx:id="btnNavMap" styleClass="nav-item,nav-item-active" onAction="#onNavMap" maxWidth="Infinity"/>
                <Button fx:id="btnNavHistory" styleClass="nav-item" onAction="#onNavHistory" maxWidth="Infinity"/>
                <Button fx:id="btnNavPayments" styleClass="nav-item" onAction="#onNavPayments" maxWidth="Infinity"/>
                <Button fx:id="btnNavPromotions" styleClass="nav-item" onAction="#onNavPromotions" maxWidth="Infinity"/>
                <Button fx:id="btnNavSettings" styleClass="nav-item" onAction="#onNavSettings" maxWidth="Infinity"/>
            </VBox>

            <!-- User profile -->
            <VBox spacing="0" style="-fx-padding:12 20 8 20; -fx-border-color:#1e3a5f; -fx-border-width:1 0 0 0;">
                <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding:8 0 8 0;">
                    <StackPane style="-fx-background-color:#1e3a5f; -fx-background-radius:50%; -fx-min-width:36px; -fx-min-height:36px;" alignment="CENTER">
                        <Label text="👤" style="-fx-font-size:16px;"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="lblUserName" style="-fx-text-fill:#f1f5f9; -fx-font-size:13px; -fx-font-weight:bold;"/>
                        <Label fx:id="lblUserPhone" style="-fx-text-fill:#475569; -fx-font-size:11px;"/>
                    </VBox>
                </HBox>
                <Button fx:id="btnSupport" styleClass="nav-item" onAction="#onSupport" maxWidth="Infinity"/>
                <Button fx:id="btnSignOut" styleClass="nav-item" onAction="#onSignOut" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>

    <!-- Main content area -->
    <center>
        <StackPane fx:id="contentArea">
            <!-- Map background placeholder -->
            <Pane fx:id="mapPane" styleClass="map-placeholder" style="-fx-background-color:#0d1526;"/>

            <!-- Price surge badge (top right) -->
            <HBox alignment="TOP_RIGHT" style="-fx-padding:16;">
                <VBox spacing="8" alignment="TOP_RIGHT">
                    <Label fx:id="lblPriceSurge" styleClass="surge-badge" visible="false" managed="false"/>
                    <!-- Mini map compass -->
                    <VBox styleClass="card" alignment="CENTER" spacing="4"
                          style="-fx-min-width:60px; -fx-min-height:80px; -fx-padding:8;">
                        <Label text="⬆" style="-fx-text-fill:#94a3b8; -fx-font-size:14px;"/>
                        <Label text="|" style="-fx-text-fill:#475569; -fx-font-size:10px;"/>
                        <Label text="◄" style="-fx-text-fill:#94a3b8; -fx-font-size:14px;"/>
                    </VBox>
                </VBox>
            </HBox>

            <!-- Booking panel (center-left overlay) -->
            <HBox alignment="CENTER_LEFT" style="-fx-padding:20 0 0 20;" StackPane.alignment="TOP_LEFT">
                <VBox fx:id="bookingPanel" styleClass="card" spacing="16" maxWidth="320">

                    <Label fx:id="lblWhereTo" styleClass="label-title" style="-fx-font-size:22px;"/>
                    <Label fx:id="lblWhereToAmharic" styleClass="label-subtitle"/>

                    <!-- Pickup -->
                    <VBox spacing="6">
                        <Label fx:id="lblPickup" styleClass="label-section"/>
                        <HBox spacing="10" alignment="CENTER_LEFT"
                              style="-fx-background-color:#0d1526; -fx-border-color:#1e3a5f; -fx-border-radius:8px; -fx-background-radius:8px; -fx-padding:10 14;">
                            <Label text="⊙" style="-fx-text-fill:#3b82f6; -fx-font-size:14px;"/>
                            <TextField fx:id="tfPickup"
                                       style="-fx-background-color:transparent; -fx-text-fill:#f1f5f9; -fx-border-color:transparent; -fx-font-size:13px;"
                                       HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <!-- Destination -->
                    <VBox spacing="6">
                        <Label fx:id="lblDestination" styleClass="label-section"/>
                        <HBox spacing="10" alignment="CENTER_LEFT"
                              style="-fx-background-color:#0d1526; -fx-border-color:#1e3a5f; -fx-border-radius:8px; -fx-background-radius:8px; -fx-padding:10 14;">
                            <Label text="📍" style="-fx-text-fill:#f59e0b; -fx-font-size:14px;"/>
                            <TextField fx:id="tfDestination"
                                       style="-fx-background-color:transparent; -fx-text-fill:#f1f5f9; -fx-prompt-text-fill:#475569; -fx-border-color:transparent; -fx-font-size:13px;"
                                       HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <!-- Ride categories -->
                    <HBox spacing="8">
                        <VBox fx:id="tileEconomy" styleClass="ride-tile,ride-tile-selected" alignment="CENTER" spacing="4" onMouseClicked="#onSelectEconomy">
                            <Label text="🚗" style="-fx-font-size:20px;"/>
                            <Label fx:id="lblEconomy" style="-fx-text-fill:#94a3b8; -fx-font-size:9px; -fx-font-weight:bold;"/>
                            <Label fx:id="lblEconomyFare" style="-fx-text-fill:#f1f5f9; -fx-font-size:11px;"/>
                        </VBox>
                        <VBox fx:id="tilePremium" styleClass="ride-tile" alignment="CENTER" spacing="4" onMouseClicked="#onSelectPremium">
                            <Label text="🚐" style="-fx-font-size:20px;"/>
                            <Label fx:id="lblPremium" style="-fx-text-fill:#94a3b8; -fx-font-size:9px; -fx-font-weight:bold;"/>
                            <Label fx:id="lblPremiumFare" style="-fx-text-fill:#f1f5f9; -fx-font-size:11px;"/>
                        </VBox>
                        <VBox fx:id="tileElite" styleClass="ride-tile" alignment="CENTER" spacing="4" onMouseClicked="#onSelectElite">
                            <Label text="🚙" style="-fx-font-size:20px;"/>
                            <Label fx:id="lblElite" style="-fx-text-fill:#94a3b8; -fx-font-size:9px; -fx-font-weight:bold;"/>
                            <Label fx:id="lblEliteFare" style="-fx-text-fill:#f1f5f9; -fx-font-size:11px;"/>
                        </VBox>
                    </HBox>

                    <!-- Phone input -->
                    <HBox spacing="0" style="-fx-background-color:#0d1526; -fx-border-color:#1e3a5f; -fx-border-radius:8px; -fx-background-radius:8px;">
                        <Label text="+251" style="-fx-text-fill:#94a3b8; -fx-padding:10 10 10 14; -fx-font-size:13px;"/>
                        <Separator orientation="VERTICAL" style="-fx-background-color:#1e3a5f;"/>
                        <TextField fx:id="tfPassengerPhone" promptText="911 234 567"
                                   style="-fx-background-color:transparent; -fx-text-fill:#f1f5f9; -fx-prompt-text-fill:#475569; -fx-border-color:transparent; -fx-padding:10 14 10 10; -fx-font-size:13px;"
                                   HBox.hgrow="ALWAYS"/>
                        <Button text="✕" onAction="#onClearPhone"
                                style="-fx-background-color:transparent; -fx-text-fill:#475569; -fx-cursor:hand; -fx-padding:10 14 10 4;"/>
                    </HBox>

                    <!-- Request Ride button -->
                    <Button fx:id="btnRequestRide" styleClass="btn-primary" onAction="#onRequestRide"
                            maxWidth="Infinity"
                            style="-fx-background-color:#3b82f6; -fx-text-fill:white; -fx-font-size:14px; -fx-font-weight:bold; -fx-padding:14; -fx-background-radius:10px; -fx-cursor:hand;"/>
                </VBox>
            </HBox>

            <!-- Quick locations bar (bottom) -->
            <HBox fx:id="quickLocationsBar" alignment="CENTER" spacing="24"
                  style="-fx-padding:12 24; -fx-background-color:rgba(13,21,38,0.85);"
                  StackPane.alignment="BOTTOM_CENTER">
                <VBox alignment="CENTER" spacing="4" onMouseClicked="#onQuickHome" style="-fx-cursor:hand;">
                    <Label text="🏠" style="-fx-font-size:18px;"/>
                    <Label fx:id="lblHome" style="-fx-text-fill:#f1f5f9; -fx-font-size:12px; -fx-font-weight:bold;"/>
                    <Label fx:id="lblHomeAddr" style="-fx-text-fill:#475569; -fx-font-size:10px;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="4" onMouseClicked="#onQuickWork" style="-fx-cursor:hand;">
                    <Label text="💼" style="-fx-font-size:18px;"/>
                    <Label fx:id="lblWork" style="-fx-text-fill:#f1f5f9; -fx-font-size:12px; -fx-font-weight:bold;"/>
                    <Label fx:id="lblWorkAddr" style="-fx-text-fill:#475569; -fx-font-size:10px;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="4" onMouseClicked="#onQuickFavorites" style="-fx-cursor:hand;">
                    <Label text="⭐" style="-fx-font-size:18px;"/>
                    <Label fx:id="lblFavorites" style="-fx-text-fill:#f1f5f9; -fx-font-size:12px; -fx-font-weight:bold;"/>
                    <Label fx:id="lblFavoritesAddr" style="-fx-text-fill:#475569; -fx-font-size:10px;"/>
                </VBox>
            </HBox>
        </StackPane>
    </center>
</BorderPane>
