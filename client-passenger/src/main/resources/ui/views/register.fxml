<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.ethioride.passenger.ui.controllers.RegisterController"
           stylesheets="@../styles/dark-theme.css"
           style="-fx-background-color: #0a0e1a;"
           prefWidth="480" prefHeight="780">

    <ScrollPane fitToWidth="true" style="-fx-background-color:transparent; -fx-background:transparent;">
        <VBox spacing="0" maxWidth="360" alignment="CENTER" style="-fx-padding:0 20 0 20;">

            <!-- Top bar -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <padding><Insets top="20" bottom="10"/></padding>
                <Button text="←" onAction="#onBack"
                        style="-fx-background-color:transparent; -fx-text-fill:#94a3b8; -fx-font-size:18px; -fx-cursor:hand;"/>
                <Label fx:id="lblRegisterTitle" styleClass="label-title" style="-fx-font-size:18px;"/>
            </HBox>

            <!-- Subtitle -->
            <Label fx:id="lblCreateAccount" styleClass="label-title" style="-fx-font-size:20px; -fx-padding:0 0 20 0;"/>

            <!-- Form fields -->
            <VBox spacing="14">

                <!-- Full Name -->
                <VBox spacing="6">
                    <Label fx:id="lblFullName" styleClass="label-section"/>
                    <TextField fx:id="tfFullName" promptText="John Doe" styleClass="text-field-dark" maxWidth="Infinity"/>
                </VBox>

                <!-- Phone -->
                <VBox spacing="6">
                    <Label fx:id="lblPhone" styleClass="label-section"/>
                    <HBox spacing="0" style="-fx-background-color:#0d1526; -fx-border-color:#1e3a5f; -fx-border-radius:8px; -fx-background-radius:8px;">
                        <Label text="+251" style="-fx-text-fill:#94a3b8; -fx-padding:10 10 10 14; -fx-font-size:13px; -fx-min-width:60px;"/>
                        <Separator orientation="VERTICAL" style="-fx-background-color:#1e3a5f;"/>
                        <TextField fx:id="tfPhone" promptText="911 234567"
                                   style="-fx-background-color:transparent; -fx-text-fill:#f1f5f9; -fx-prompt-text-fill:#475569; -fx-border-color:transparent; -fx-padding:10 14 10 10; -fx-font-size:13px;"
                                   HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- Email -->
                <VBox spacing="6">
                    <Label fx:id="lblEmail" styleClass="label-section"/>
                    <TextField fx:id="tfEmail" promptText="example@domain.com" styleClass="text-field-dark" maxWidth="Infinity"/>
                </VBox>

                <!-- Password -->
                <VBox spacing="6">
                    <Label fx:id="lblPassword" styleClass="label-section"/>
                    <HBox spacing="0" style="-fx-background-color:#0d1526; -fx-border-color:#1e3a5f; -fx-border-radius:8px; -fx-background-radius:8px;">
                        <PasswordField fx:id="pfPassword" promptText="••••••••"
                                       style="-fx-background-color:transparent; -fx-text-fill:#f1f5f9; -fx-prompt-text-fill:#475569; -fx-border-color:transparent; -fx-padding:10 14 10 14; -fx-font-size:13px;"
                                       HBox.hgrow="ALWAYS"/>
                        <Button text="👁" onAction="#onTogglePassword"
                                style="-fx-background-color:transparent; -fx-text-fill:#475569; -fx-cursor:hand; -fx-padding:10 14 10 4;"/>
                    </HBox>
                </VBox>

                <!-- Confirm Password -->
                <VBox spacing="6">
                    <Label fx:id="lblConfirmPassword" styleClass="label-section"/>
                    <PasswordField fx:id="pfConfirmPassword" promptText="••••••••" styleClass="password-field-dark" maxWidth="Infinity"/>
                </VBox>

                <!-- Terms -->
                <HBox spacing="10" alignment="TOP_LEFT">
                    <CheckBox fx:id="cbTerms" style="-fx-text-fill:#94a3b8;"/>
                    <Label fx:id="lblTerms" styleClass="label-subtitle" wrapText="true" maxWidth="280"/>
                </HBox>

                <!-- Error -->
                <Label fx:id="lblError" style="-fx-text-fill:#ef4444; -fx-font-size:12px;" visible="false" managed="false"/>

                <!-- Sign Up button -->
                <Button fx:id="btnSignUp" styleClass="btn-primary" onAction="#onSignUp"
                        maxWidth="Infinity" style="-fx-background-color:#3b82f6; -fx-text-fill:white; -fx-font-size:14px; -fx-font-weight:bold; -fx-padding:12; -fx-background-radius:10px; -fx-cursor:hand;"/>

                <!-- Login link -->
                <HBox alignment="CENTER" spacing="4">
                    <padding><Insets top="8" bottom="40"/></padding>
                    <Label fx:id="lblHaveAccount" styleClass="label-subtitle"/>
                    <Label fx:id="lblLogin" styleClass="label-link" onMouseClicked="#onLogin"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</StackPane>
